# ─── ColorCraft Studio — Environment Variables ───────────────────────────────
#
# Copy this file to .env and fill in your values.
# .env is gitignored and never committed to source control.
#
#   cp .env.example .env
#
# In Portainer: paste these into the "Environment variables" section
# of your stack, or reference this file via "env_file" in compose.
# ─────────────────────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────────────────────

# Port the app listens on inside the container.
# The docker-compose.yml maps this to the host (default: 3000).
PORT=3000

# ── Gemini AI (optional) ──────────────────────────────────────────────────────
# Get a free key at: https://aistudio.google.com/apikey
# If left empty, the app works fine — coloring pages still generate,
# you just won't get the AI coloring tips after each conversion.

GEMINI_API_KEY=

# The Gemini model to use. Change this if your account has access to
# a different model. gemini-2.0-flash works on most free tier accounts.
GEMINI_MODEL=gemini-2.0-flash
